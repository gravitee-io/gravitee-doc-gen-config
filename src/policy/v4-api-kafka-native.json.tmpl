{
  "api": {
    "definitionVersion": "V4",
    "type": "NATIVE",
    "name": "{{ .Title }} example API",
    "flows": [
      {
        "name": "Common Flow",
        "enabled": true,
        "selectors": [
          {
            "type": "CHANNEL",
            "channel": "/",
            "channelOperator": "STARTS_WITH"
          }
        ],
        "{{ .Properties.phase }}": [
          {
            "name": "{{ .Title }}",
            "enabled": true,
            "policy": "{{ .ID }}",
            "configuration":
              {{ indent 14 .Node }}
          }
        ]
      }
    ]
  }
}
